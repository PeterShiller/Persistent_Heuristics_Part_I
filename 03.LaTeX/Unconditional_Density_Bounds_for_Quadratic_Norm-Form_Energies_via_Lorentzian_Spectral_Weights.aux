\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Spacelike verification across admissible weights. All computations use ARB interval arithmetic at 512-bit precision, so every entry is a rigorous certified value. The $\zeta $ sum uses 60 zeros (Appendix\nonbreakingspace \ref {app:zeta-zeros}); the $L$-function sums use 60 certified zeros for $\chi _5$ and 20 certified zeros for $\chi _2$, $\chi _3$, $\chi _{13}$ (from Appendices\nonbreakingspace \ref {app:chi8-zeros}--\ref {app:chi28-zeros}). The norm form is $N_w = S_\zeta (w)^2 - d\cdot S_L(w)^2$ with squarefree $d$. Every $N_w$ entry is rigorously negative: the ARB ball lies entirely below zero. Entries rounded to four significant figures.}}{47}{table.2}\protected@file@percent }
\newlabel{tab:weights}{{2}{47}{Spacelike verification across admissible weights. All computations use ARB interval arithmetic at 512-bit precision, so every entry is a rigorous certified value. The $\zeta $ sum uses 60 zeros (Appendix~\ref {app:zeta-zeros}); the $L$-function sums use 60 certified zeros for $\chi _5$ and 20 certified zeros for $\chi _2$, $\chi _3$, $\chi _{13}$ (from Appendices~\ref {app:chi8-zeros}--\ref {app:chi28-zeros}). The norm form is $N_w = S_\zeta (w)^2 - d\cdot S_L(w)^2$ with squarefree $d$. Every $N_w$ entry is rigorously negative: the ARB ball lies entirely below zero. Entries rounded to four significant figures}{table.2}{}}
